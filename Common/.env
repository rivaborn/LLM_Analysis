# .env -- LLM_Analysis pipeline configuration (Claude CLI variant)
#
# Location: LLM_Analysis/Common/.env
# Read by every PS1 in Analysis/ via the shared module
# (Analysis/<script>.ps1 -> ../Common/llm_common.ps1).
#
# This toolkit drives the Claude CLI (`claude -p ...`) per script,
# not Ollama. The sister LocalLLM_Analysis toolkit uses Ollama and
# has a different .env schema (LLM_HOST/LLM_MODEL/LLM_NUM_CTX/etc.).

# ── Claude CLI accounts (dual-account rotation) ──
# Each script can use either `-Claude1` (default) or `-Claude2` to
# rotate between accounts via CLAUDE_CONFIG_DIR.
CLAUDE1_CONFIG_DIR="$HOME\.claudemain"
CLAUDE2_CONFIG_DIR="$HOME\.claudealt"

# ── Claude CLI invocation defaults ──
CLAUDE_MODEL=haiku
CLAUDE_MAX_TURNS=1
CLAUDE_OUTPUT_FORMAT=text

# ── Retries ──
PROGRESS_INTERVAL=1
MAX_RETRIES=2
RETRY_DELAY=5

# ── Codebase ──
PRESET=unreal

CODEBASE_DESC="Unreal Engine source (Epic Games). Large-scale C++ game engine: Core (memory/containers/math/logging), CoreUObject (UObject reflection/GC/CDO), Engine (actors/components/world), Renderer (deferred shading, RHI abstraction over D3D12/Vulkan/Metal), PhysicsCore/Chaos, AudioMixerCore, AIModule, GameplayAbilities (GAS), Slate/UMG UI, NetworkCore (replication/RPCs). UHT generates reflection code. Blueprint VM, delegates, TWeakObjectPtr, FName/FText/FString, UBT build system."

INCLUDE_EXT_REGEX=\.(cpp|h|hpp|cc|cxx|inl|cs)$
EXCLUDE_DIRS_REGEX=[/\\](\.git|architecture|Binaries|Build|DerivedDataCache|Intermediate|Saved|\.vs|ThirdParty|GeneratedFiles|AutomationTool)([/\\]|$)

# ── File handling ──
BUNDLE_HEADERS=1
MAX_BUNDLED_HEADERS=8

# Truncate very large UE headers (Actor.h etc can be 5000+ lines)
MAX_FILE_LINES=3000

# UE is huge — chunked overview is essential
CHUNK_THRESHOLD=1500

# Trivial-file detection (used by Test-TrivialFile in file_helpers.ps1)
SKIP_TRIVIAL=1
MIN_TRIVIAL_LINES=20

# ── Cross-pipeline integration paths (optional, off by default) ──
# Reserved for a future Debug pipeline that consumes Analysis outputs.
#ARCHITECTURE_DIR=architecture
#SERENA_CONTEXT_DIR=architecture/.serena_context

# ── Subsections for AnalysisPipeline.py ──
# Each line below is a subdirectory (relative to the target repo root)
# that the orchestrator walks in order. After each subsection completes,
# `architecture/` is renamed to `N. <subsection_sanitized>/`. Comment
# lines (starting with #) and blanks are ignored.
#
# Pre-populated with UE 5.x runtime subsystems. Adjust per your engine
# version. Add `Engine/Source/Editor/...` entries for editor modules;
# add `Engine/Source/Programs/...` for tools.
#Subsections begin
Engine/Source/Runtime/Core
# Memory, containers, math, platform abstractions
Engine/Source/Runtime/CoreUObject
# Reflection, GC, UObject system, CDO
Engine/Source/Runtime/Engine
# Actors, components, world, gameplay framework
Engine/Source/Runtime/Renderer
# Deferred shading, scene rendering pipeline
Engine/Source/Runtime/RenderCore
# Render thread, RHI command lists, shader management
Engine/Source/Runtime/RHI
# RHI abstraction over D3D12 / Vulkan / Metal
Engine/Source/Runtime/PhysicsCore
# Physics interface (Chaos backend)
Engine/Source/Runtime/AudioMixerCore
# Audio mixer / submixes
Engine/Source/Runtime/AIModule
# Behavior trees, EQS, navigation
Engine/Source/Runtime/GameplayAbilities
# GAS — abilities, attributes, gameplay effects
Engine/Source/Runtime/SlateCore
# Slate widget primitives
Engine/Source/Runtime/Slate
# Slate widget library
Engine/Source/Runtime/UMG
# UI Builder on top of Slate
Engine/Source/Runtime/NetworkCore
# Replication and RPC plumbing
#Subsections end
